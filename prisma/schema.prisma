generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  date      String
  time      String
  reason    String
  createdAt DateTime @default(now())
}